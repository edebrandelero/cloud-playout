PORT=3000
NODE_ENV=development

# Banco SQLite (canais, assets, playlists persistem entre reinícios)
DATABASE_PATH=./data/cloud-playout.db

# Segurança — defina uma chave forte em produção
API_KEY=change-me-in-production
REQUIRE_AUTH=true

# Rate limiting (por IP)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX=10

# Limites de payload
MAX_BODY_BYTES=1048576
MAX_UPLOAD_BYTES=524288000

# ffmpeg | simulation
PLAYOUT_ENGINE=ffmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Pasta com arquivos de mídia (paths relativos dos assets)
MEDIA_ROOT=./media

# Saída HLS local (quando channel.outputUrl não for RTMP)
HLS_OUTPUT_DIR=./output/hls

# CORS (origens separadas por vírgula, vazio = desabilitado)
# CORS_ORIGINS=https://meu-painel.com
